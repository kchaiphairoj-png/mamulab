# ---------- Supabase (Auth + DB + Storage for membership) ----------
# Project Settings → API บน Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------- Membership pricing ----------
MEMBERSHIP_PRICE=199
MEMBERSHIP_DURATION_DAYS=30

# ---------- Bank account สำหรับรับเงิน (แสดงให้ลูกค้าโอน) ----------
NEXT_PUBLIC_PAYMENT_BANK_NAME=ธนาคารกรุงเทพ
NEXT_PUBLIC_PAYMENT_BANK_SHORT=BBL
NEXT_PUBLIC_PAYMENT_ACCOUNT_NUMBER=1688204379
NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME=บจก. แมงโก้ ลัคกี้

# ---------- Slip verification ----------
# Verification is done in-app by reading the QR on the slip + checking for
# duplicate submissions. No external service is required.

# ---------- Lead capture ----------
# Webhook ที่จะรับ lead — รองรับ Google Apps Script / Zapier / Make / n8n
# วิธี Google Sheets: สร้าง Apps Script ตามตัวอย่างใน docs/google-sheets-webhook.md
LEAD_WEBHOOK_URL=

# ---------- Analytics ----------
# Google Analytics 4 (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# ---------- Brand / Social ----------
# LINE OA แอดเพื่อน URL (เช่น https://lin.ee/xxxxxx)
NEXT_PUBLIC_LINE_OA_URL=https://lin.ee/your-line-id
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/mamulab
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@mamulab
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/mamulab
